# CityPulse Configuration
# This is a demo environment configuration

# Application
NEXT_PUBLIC_APP_NAME=CityPulse
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=development

# Features (all enabled by default in demo mode)
NEXT_PUBLIC_ENABLE_REPORTS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_AUDIT_LOGS=true
NEXT_PUBLIC_ENABLE_EXPORTS=true

# Database Configuration (when backend is implemented)
# DATABASE_URL=postgresql://user:password@localhost:5432/citypulse
# DATABASE_USER=citypulse_user
# DATABASE_PASSWORD=secure_password

# Authentication (when backend auth is implemented)
# AUTH_SECRET=your_secret_key_here
# NEXT_PUBLIC_AUTH_ENABLED=false

# API Configuration (when APIs are implemented)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# NEXT_PUBLIC_MAP_API_KEY=your_map_key_here

# Email Service (for notifications - future feature)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Analytics (future feature)
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id
# NEXT_PUBLIC_ERROR_TRACKING=true

# Deployment
# VERCEL_ENV=production
# VERCEL_URL=https://citypulse.vercel.app
